{
  "name": "chainsolve-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run wasm:build && tsc -b && vite build",
    "wasm:build": "RUSTFLAGS='-C target-feature=+simd128' wasm-pack build crates/engine-wasm --target web --release && node scripts/optimize-wasm.mjs",
    "wasm:build:dev": "RUSTFLAGS='-C target-feature=+simd128' wasm-pack build crates/engine-wasm --target web --dev",
    "wasm:test": "cargo test --workspace",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "npm run wasm:build && tsc -b --noEmit",
    "typecheck:functions": "tsc -p functions/tsconfig.json --noEmit",
    "check": "npm run format:check && npm run lint && npx tsc -b --noEmit && npm run typecheck:functions",
    "preview": "vite preview",
    "test:e2e": "playwright test --project=full",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:full": "playwright test --project=full",
    "test:e2e:visual": "playwright test --project=visual",
    "test:e2e:a11y": "playwright test --project=a11y",
    "test:e2e:chaos": "playwright test --project=chaos",
    "test:e2e:ui": "playwright test --ui",
    "bench:rust": "cargo bench --package engine-core",
    "perf:bundle": "node scripts/check-bundle-size.mjs",
    "perf:engine": "cargo bench --package engine-core 2>&1 | tail -60",
    "perf:all": "npm run perf:bundle",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "verify:fast": "bash scripts/verify-fast.sh",
    "verify:ci": "bash scripts/verify-ci.sh",
    "check:wasm-exports": "node scripts/check-wasm-exports.mjs",
    "doctor": "node scripts/doctor.mjs",
    "licence:rust": "node scripts/gen-rust-licences.mjs",
    "licence:frontend": "npx license-checker --json --out legal/frontend-dependency-licences.json && npx license-checker --failOn \"GPL-2.0;GPL-3.0;AGPL-3.0;SSPL-1.0\"",
    "licence:all": "npm run licence:rust && npm run licence:frontend",
    "sbom": "bash scripts/gen-sbom.sh",
    "sbom:rust": "cargo sbom --output-format cyclone_dx_json_1_6 > legal/sbom/rust-sbom.cdx.json",
    "sbom:npm": "npx --yes @cyclonedx/cyclonedx-npm --spec-version 1.6 --output-format JSON --output-file legal/sbom/npm-sbom.cdx.json --package-lock-only",
    "legal-pack": "bash scripts/gen-legal-pack.sh",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:build:cuda": "tauri build -- --features cuda",
    "docs:api": "typedoc",
    "docs:api:watch": "typedoc --watch",
    "db:types": "supabase gen types typescript --local > src/lib/database.types.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@sentry/react": "^10.45.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@xyflow/react": "^12.10.1",
    "dagre": "^0.8.5",
    "html-to-image": "^1.11.13",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "katex": "^0.16.38",
    "lucide-react": "^0.577.0",
    "onnxruntime-web": "^1.24.3",
    "pdf-lib": "^1.17.1",
    "posthog-js": "^1.363.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "stripe": "^20.4.1",
    "vega": "^6.2.0",
    "vega-interpreter": "^2.2.1",
    "vega-lite": "^6.4.2",
    "web-vitals": "^5.1.0",
    "write-excel-file": "^3.0.6",
    "yjs": "^13.6.30",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "minimatch@>=10.0.0 <10.2.3": "10.2.4",
    "minimatch@>=3.0.0 <3.1.4": "3.1.5",
    "test-exclude": "8.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@storybook/react-vite": "^10.3.2",
    "@types/dagre": "^0.7.54",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@webgpu/types": "^0.1.69",
    "binaryen": "^124.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "storybook": "^10.2.17",
    "typedoc": "^0.28.7",
    "typedoc-plugin-markdown": "^4.6.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
