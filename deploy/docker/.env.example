# ChainSolve Self-Hosted — Environment Variables
# Copy this to .env and fill in the values before running docker compose up.
#
# SECURITY WARNING: Never commit your .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Strong random password for the Postgres superuser
POSTGRES_PASSWORD=change_me_strong_password_here

# ── Supabase JWT ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=change_me_jwt_secret_here

# Anon key (public) — generate at https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
SUPABASE_ANON_KEY=change_me_anon_key_here

# Service role key (private, server-side only)
SUPABASE_SERVICE_ROLE_KEY=change_me_service_role_key_here

# ── Application ───────────────────────────────────────────────────────────────
# Public URL of your ChainSolve instance
SITE_URL=http://localhost:8080

# ── Realtime ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
REALTIME_ENC_KEY=change_me_realtime_enc_key
# Generate with: mix phx.gen.secret (or openssl rand -base64 64)
SECRET_KEY_BASE=change_me_secret_key_base

# ── SMTP (optional — for email auth) ─────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Stripe (optional — for billing) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Logflare (optional — for analytics) ──────────────────────────────────────
LOGFLARE_API_KEY=
