# Cloudflare Pages — security + caching headers
# Applied to all routes. Functions (/api/*) can set their own headers.
# Order matters: specific rules must come BEFORE the catch-all.

# ── Vite hashed assets — immutable forever ───────────────────────────────────
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# ── Brand assets — immutable (filenames are stable, content rarely changes) ──
/brand/*
  Cache-Control: public, max-age=31536000, immutable

# ── Infrequently changing static files ───────────────────────────────────────
/favicon.ico
  Cache-Control: public, max-age=86400

/favicon-*.png
  Cache-Control: public, max-age=86400

/apple-touch-icon.png
  Cache-Control: public, max-age=86400

/icon-*.png
  Cache-Control: public, max-age=86400

/og-image.png
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

/site.webmanifest
  Cache-Control: public, max-age=86400

# ── Everything else (HTML, SPA routes) — always revalidate ───────────────────
#
# CLOUDFLARE WEB ANALYTICS — MUST BE DISABLED (G0-3 resolution).
# The beacon (static.cloudflareinsights.com/beacon.min.js) is NOT
# allowlisted in script-src. If "Web Analytics" is enabled in the
# Cloudflare dashboard, the injected script is blocked by CSP.
# Official resolution: disable "Web Analytics" in Cloudflare Pages
# dashboard (Speed → Web Analytics → OFF). See docs/SECURITY.md §5
# and docs/ANALYTICS_STRATEGY.md for rationale.
/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=(), payment=(), usb=(), bluetooth=()
  X-XSS-Protection: 0
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  # ENG-02: COOP/COEP enable SharedArrayBuffer for zero-copy dataset transfer.
  # require-corp enforces that all embedded cross-origin resources must opt in
  # via their own CORP header. Stripe, Cloudflare, and Google Fonts all do so.
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  # 'wasm-unsafe-eval' permits WebAssembly.instantiateStreaming() in the Rust/WASM
  # engine worker without enabling arbitrary eval(). See docs/SECURITY.md §2.
  # CSP reports route to /api/report/csp (W9.8 observability pipeline).
  # V2-004: Report-Only removed — it was identical to the enforced CSP, causing
  # duplicate violation reports with no benefit. To test a stricter policy in
  # the future, temporarily add a Content-Security-Policy-Report-Only header
  # with the tighter directives, observe reports, then promote to enforced.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval' https://challenges.cloudflare.com https://plausible.io; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.stripe.com https://*.sentry.io https://eu.i.posthog.com https://t.chainsolve.co.uk https://plausible.io; frame-src https://js.stripe.com https://challenges.cloudflare.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; report-uri /api/report/csp; report-to csp-endpoint
  Reporting-Endpoints: csp-endpoint="/api/report/csp"
